# --- Admin ---
# Shared secret for the admin page (/admin) and admin API (/api/admin/*).
# The admin page sends it as: Authorization: Bearer <ADMIN_PASSWORD>
# REQUIRED to issue/revoke API keys. Change this to a strong random value.
ADMIN_PASSWORD=change-me-admin-secret

# --- API authentication ---
# Optional: seed keys from this comma-separated list on first run.
# Keys created via /admin are stored in data/apikeys.json and take over.
# Default quota per seeded key = DEFAULT_QUOTA below.
API_KEYS=
DEFAULT_QUOTA=1000

# --- Web UI limits (enforced on /api/web/process) ---
# Max number of files per single upload (default 20).
WEB_MAX_FILES=20
# Max size per file in bytes (default 5 MB).
WEB_MAX_FILE_SIZE=5242880

# --- Limits & defaults ---
# Maximum upload size per file for the /v1 API, in bytes (default 10 MB).
MAX_FILE_SIZE=10485760

# Default quality (1-100) used when the client does not provide one.
DEFAULT_QUALITY=80
